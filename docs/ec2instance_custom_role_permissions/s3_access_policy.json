{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ListElements",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::my-cool-terraform-bucket-version-3"
            ]
        },
        {
            "Sid": "Actions",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::my-cool-terraform-bucket-version-3/*"
            ]
        }
    ]
}